# ============================================================
# PI Governance Rust Workspace
# Do not commit local stores, build outputs, secrets, or tooling noise.
# ============================================================

# Rust build output
/target/

# Local PI stores / governed memory data
.pi/
*.pi/
**/.pi/

# Local runtime data
*.jsonl
*.jsonl.tmp
*.lock
*.pid

# Environment / secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.token
*.secret
secrets/
.secret/

# Logs
*.log
logs/
debug.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor / IDE local state
.vscode/
.idea/
*.swp
*.swo
*.swn
*~

# Rust analyzer / local cache
.rust-analyzer/
.cache/

# Node / MCP Inspector / JS tooling cache
node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn-cache/

# Local MCP/client configs that may contain absolute paths or secrets
.mcp.json
mcp.json
mcp.settings.json
claude_desktop_config.json

# Agent/dev-tool local files
.aider*
.cursor/
.codex/
.claude/
.continue/
.zed/
.replit
replit.nix

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# Archives / generated exports
*.zip
*.tar
*.tar.gz
*.tgz
